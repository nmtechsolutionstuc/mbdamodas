generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum SubmissionItemStatus {
  PENDING    // Enviada, esperando revisión del admin
  APPROVED   // Aprobada, genera un Item en catálogo
  REJECTED   // Rechazada por el admin (con comentario)
  IN_STORE   // Confirmada físicamente en tienda/vidriera
  SOLD       // Vendida — se calcula comisión
  RETURNED   // Devuelta al vendedor
}

enum ItemCondition {
  NUEVA_CON_ETIQUETA  // Nueva, con etiqueta original
  NUEVA_SIN_ETIQUETA  // Nueva, sin etiqueta (sin uso)
  COMO_NUEVA          // Usada 1-2 veces
  BUEN_ESTADO         // Signos mínimos de uso
  USO_MODERADO        // Desgaste visible pero aceptable
  USO_INTENSO         // Desgaste notable
}

enum MiniShopStatus {
  ACTIVE
  PAUSED
  DELETED
}

enum MiniShopProductStatus {
  PENDING
  APPROVED
  REJECTED
  PAUSED
}

enum ReservationStatus {
  PENDING_APPROVAL  // Creada por el usuario, esperando confirmación del admin
  APPROVED          // Aprobada — producto reservado por 24h
  REJECTED          // Rechazada por el admin (con motivo)
  COMPLETED         // Venta realizada — promotor cobra comisión
  CANCELLED         // Cancelada por el usuario (solo desde PENDING_APPROVAL)
  EXPIRED           // Venció el plazo de 24h sin completarse
}

// ─────────────────────────────────────────────────────────────
// PRODUCT TYPE — Reemplaza ItemCategory. Tipos de producto parametrizables.
// ─────────────────────────────────────────────────────────────

model ProductType {
  id           String   @id @default(uuid())
  name         String   @unique  // "Ropa", "Calzado", "Otro"
  code         String   @unique  // "ROPA", "CALZADO", "OTRO"
  requiresSize Boolean  @default(true) // false for "OTRO"
  isActive     Boolean  @default(true)
  order        Int      @default(0) // for display ordering
  createdAt    DateTime @default(now())

  items              Item[]
  submissionItems    SubmissionItem[]
  tags               Tag[]
  sizes              Size[]
  miniShopProducts   MiniShopProduct[]

  @@map("product_types")
}

// ─────────────────────────────────────────────────────────────
// SIZE — Reemplaza ItemSize. Talles parametrizables por tipo de producto.
// ─────────────────────────────────────────────────────────────

model Size {
  id        String   @id @default(uuid())
  name      String   // "XS", "S", "M", "L", "XL", "36", "37", "38", etc.
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id])

  items              Item[]
  submissionItems    SubmissionItem[]
  miniShopProducts   MiniShopProduct[]

  @@unique([productTypeId, name])
  @@index([productTypeId])
  @@map("sizes")
}

// ─────────────────────────────────────────────────────────────
// TAG — Etiquetas parametrizables por tipo de producto.
// ─────────────────────────────────────────────────────────────

model Tag {
  id        String   @id @default(uuid())
  name      String   // "Deportivo", "Casual", "Formal", etc.
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id])

  items              ItemTag[]
  submissionItems    SubmissionItemTag[]
  miniShopProducts   MiniShopProductTag[]

  @@unique([productTypeId, name])
  @@index([productTypeId])
  @@map("tags")
}

model ItemTag {
  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@map("item_tags")
}

model SubmissionItemTag {
  submissionItemId String
  submissionItem   SubmissionItem @relation(fields: [submissionItemId], references: [id], onDelete: Cascade)
  tagId            String
  tag              Tag            @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([submissionItemId, tagId])
  @@map("submission_item_tags")
}

// ─────────────────────────────────────────────────────────────
// STORE — Entidad raíz. Todo pertenece a una tienda.
// Diseñado para soportar múltiples tiendas desde el inicio.
// ─────────────────────────────────────────────────────────────

model Store {
  id                String   @id @default(uuid())
  name              String
  address           String?
  phone             String?  // WhatsApp de la tienda (para links de comprador)
  email             String?
  description       String?
  logoUrl           String?
  defaultCommission Decimal  @db.Decimal(5, 2) @default(30) // % comisión por defecto
  announcementText   String?  // Texto del banner de anuncios (editable por admin)
  announcementActive Boolean  @default(false) // Mostrar o no el banner

  // ── Banners editables de la homepage ──
  bannerBuyerSubtitle      String?  // Subtítulo del panel comprador
  bannerBuyerTitle         String?  // Título principal del panel comprador
  bannerBuyerDescription   String?  // Descripción del panel comprador
  bannerBuyerButtonActive  Boolean  @default(true)  // Mostrar botón del panel comprador
  bannerSellerSubtitle     String?  // Subtítulo del panel vendedor/promotor
  bannerSellerTitle        String?  // Título principal del panel vendedor/promotor
  bannerSellerDescription  String?  // Descripción del panel vendedor/promotor
  bannerSellerButtonActive Boolean  @default(true)  // Mostrar botón del panel vendedor
  // ── Menú configurable de usuarios ──
  menuConfig               Json?    // Configuración de visibilidad y títulos del menú
  // ── Cards de propuesta de valor (homepage) ──
  featureCards             Json?    // Configuración de las 3 cards de propuesta de valor
  // ── Configuración botones banner vendedor ──
  bannerReservarButtonActive Boolean @default(true) // "Reservar y ganar" button
  // (bannerSellerButtonActive stays as "Quiero vender" button)
  bannerExtraButtonActive  Boolean  @default(false) // Botón extra configurable en panel vendedor
  bannerExtraButtonText    String?  // Texto del botón extra
  bannerExtraButtonUrl     String?  // URL del botón extra
  miniShopsEnabled         Boolean  @default(true)  // Activa/desactiva el módulo de mini-tiendas
  // ── Redes sociales ──
  socialLinks                Json?   // {whatsappGroup?:{active,url}, tiktok?:{active,url}, instagram?:{active,url}, facebook?:{active,url}}
  // ── Footer editable ──
  footerConfig               Json?   // {tagline?, address?, showDeveloper?}
  // ── About page config ──
  aboutConfig                Json?   // {showCatalogButton?, showVenderButton?, showWhatsappButton?, showEmailButton?}
  // ── Condiciones de producto ──
  conditionConfig            Json?   // {NUEVA_CON_ETIQUETA:{label,active,order}, ...}
  // ── Sección Destacados (home) ──
  featuredSectionTitle       String? @default("Destacados")
  // ── Sección Video (home) ──
  videoSection               Json?   // {active:bool, title:string, videoUrl:string, description:string}

  // ── Contenido editable de páginas ──
  aboutContent      String?  @db.Text // Contenido de la página Nosotros (formato markdown simple)
  termsContent      String?  @db.Text // Contenido de la página Términos y Condiciones

  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  storeAttendantPhone  String?   // teléfono del encargado de la tienda

  users        User[]
  submissions  Submission[]
  items        Item[]
  reservations Reservation[]

  @@map("stores")
}

// ─────────────────────────────────────────────────────────────
// USER — Autenticación por email + contraseña (bcryptjs)
// ─────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  googleId         String?   @unique  // Legacy / futuro OAuth — opcional
  email            String    @unique
  password         String?             // Hash bcrypt — null solo para cuentas legacy OAuth
  firstName        String
  lastName         String
  dni              String?   @unique  // DNI del vendedor (obligatorio en registro)
  phone            String?   // Número WhatsApp del vendedor
  avatarUrl        String?
  role             Role      @default(USER)
  isActive         Boolean   @default(true)
  termsAcceptedAt  DateTime? // Timestamp de aceptación de T&C (evidencia legal)
  paymentMethod    String?   // "EFECTIVO" or "TRANSFERENCIA"
  bankAlias        String?   // CBU/CVU/Alias for transfers
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  refreshTokens RefreshToken[]
  submissions   Submission[]
  reservations  Reservation[]
  miniShops     MiniShop[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// REFRESH TOKEN — Permite revocación de sesiones
// ─────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// SUBMISSION — Solicitud grupal. Agrupa N productos de un vendedor.
// ─────────────────────────────────────────────────────────────

model Submission {
  id         String   @id @default(uuid())
  adminNote  String?  // Nota general del admin sobre la solicitud
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  items SubmissionItem[]

  @@index([sellerId])
  @@index([storeId])
  @@map("submissions")
}

// ─────────────────────────────────────────────────────────────
// SUBMISSION ITEM — Producto individual dentro de una solicitud.
// Cada producto tiene su propio estado y ciclo de vida.
// ─────────────────────────────────────────────────────────────

model SubmissionItem {
  id           String               @id @default(uuid())
  title        String
  description  String?
  condition    ItemCondition
  quantity     Int                  @default(1)
  desiredPrice Decimal              @db.Decimal(10, 2)
  minimumPrice Decimal?             @db.Decimal(10, 2)
  status       SubmissionItemStatus @default(PENDING)
  adminComment String?              // Motivo de rechazo o nota del admin
  reviewedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id])

  sizeId String?
  size   Size?   @relation(fields: [sizeId], references: [id])

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  photos SubmissionItemPhoto[]
  tags   SubmissionItemTag[]
  item   Item?                 // Creado al aprobar (1:1)

  @@index([submissionId])
  @@index([status])
  @@index([productTypeId])
  @@map("submission_items")
}

// ─────────────────────────────────────────────────────────────
// SUBMISSION ITEM PHOTO — Fotos de un producto en solicitud
// ─────────────────────────────────────────────────────────────

model SubmissionItemPhoto {
  id        String   @id @default(uuid())
  url       String
  order     Int      @default(0) // 0 = foto principal
  createdAt DateTime @default(now())

  submissionItemId String
  submissionItem   SubmissionItem @relation(fields: [submissionItemId], references: [id], onDelete: Cascade)

  @@index([submissionItemId])
  @@map("submission_item_photos")
}

// ─────────────────────────────────────────────────────────────
// ITEM — Producto aprobado, visible en catálogo público.
// Se crea automáticamente al aprobar un SubmissionItem.
// ─────────────────────────────────────────────────────────────

model Item {
  id           String        @id @default(uuid())
  code         String?       @unique  // Código identificador (ej: MBDA-0001), generado al aprobar
  title        String
  description  String?
  condition    ItemCondition
  quantity     Int
  price        Decimal       @db.Decimal(10, 2)
  minimumPrice Decimal?      @db.Decimal(10, 2) // Visible solo para admin
  commission   Decimal       @db.Decimal(5, 2)  // Copiado de Store.defaultCommission al aprobar
  isActive     Boolean       @default(true)     // false = no aparece en catálogo
  soldAt       DateTime?
  returnedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id])

  sizeId String?
  size   Size?   @relation(fields: [sizeId], references: [id])

  submissionItemId String?        @unique
  submissionItem   SubmissionItem? @relation(fields: [submissionItemId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  isOwnProduct          Boolean       @default(false)
  promoterCommissionPct Decimal?      @db.Decimal(5, 2)
  featured              Boolean       @default(false)  // aparece en sección Destacados del home
  featuredAt            DateTime?                       // cuándo se activó el destacado
  featuredUntil         DateTime?                       // cuándo vence (null = sin límite)

  photos       ItemPhoto[]
  tags         ItemTag[]
  reservations Reservation[]

  @@index([storeId])
  @@index([productTypeId])
  @@index([isActive])
  @@map("items")
}

// ─────────────────────────────────────────────────────────────
// SECURITY AUDIT LOG — Registro de eventos de seguridad
// ─────────────────────────────────────────────────────────────

model SecurityLog {
  id        String   @id @default(uuid())
  event     String   // LOGIN_SUCCESS, LOGIN_FAILED, REGISTER, ADMIN_ACTION, etc.
  email     String?  // Email involucrado (si aplica)
  userId    String?  // ID del usuario (si está autenticado)
  ip        String?  // IP del cliente
  userAgent String?  // User-Agent header
  metadata  Json?    // Datos adicionales (motivo de fallo, acción admin, etc.)
  createdAt DateTime @default(now())

  @@index([event])
  @@index([email])
  @@index([userId])
  @@index([createdAt])
  @@map("security_logs")
}

// ─────────────────────────────────────────────────────────────
// ITEM PHOTO — Fotos del item en catálogo (copiadas al aprobar)
// ─────────────────────────────────────────────────────────────

model ItemPhoto {
  id        String   @id @default(uuid())
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("item_photos")
}

// ─────────────────────────────────────────────────────────────
// RESERVATION — Reservas para vender (módulo de promotores)
// ─────────────────────────────────────────────────────────────

model Reservation {
  id              String            @id @default(uuid())
  reservationCode String            @unique  // ej: RES-4821
  status          ReservationStatus @default(PENDING_APPROVAL)
  quantity        Int               @default(1)  // cantidad de unidades reservadas
  adminNote       String?
  extensionCount  Int               @default(0)
  expiresAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  itemId  String
  item    Item   @relation(fields: [itemId], references: [id])

  userId  String
  user    User   @relation(fields: [userId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  @@index([itemId])
  @@index([userId])
  @@index([status])
  @@map("reservations")
}

// ─────────────────────────────────────────────────────────────
// MINISHOP — Minitienda creada por un usuario del marketplace
// ─────────────────────────────────────────────────────────────

model MiniShop {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  description     String?
  profilePhotoUrl String?
  whatsapp        String
  socialLinks     Json?           // {instagram?, tiktok?, facebook?, otra?}
  deliveryMethods Json            // {meetingPoint: bool, address?: string, shipping: bool}
  acceptedTerms   Boolean         @default(false)
  status          MiniShopStatus  @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id])

  products MiniShopProduct[]

  @@index([userId])
  @@index([slug])
  @@index([status])
  @@map("mini_shops")
}

// ─────────────────────────────────────────────────────────────
// MINISHOP PRODUCT — Producto de una minitienda (requiere aprobación admin)
// ─────────────────────────────────────────────────────────────

model MiniShopProduct {
  id              String                  @id @default(uuid())
  title           String
  slug            String                  @unique
  description     String?
  price           Decimal                 @db.Decimal(12, 2)
  quantity        Int                     @default(1)
  status          MiniShopProductStatus   @default(PENDING)
  rejectionReason String?
  featured        Boolean                 @default(false)
  featuredAt      DateTime?
  featuredUntil   DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  miniShopId    String
  miniShop      MiniShop    @relation(fields: [miniShopId], references: [id], onDelete: Cascade)

  productTypeId String
  productType   ProductType @relation(fields: [productTypeId], references: [id])

  sizeId String?
  size   Size?   @relation(fields: [sizeId], references: [id])

  photos MiniShopProductPhoto[]
  tags   MiniShopProductTag[]

  @@index([miniShopId])
  @@index([status])
  @@index([productTypeId])
  @@map("mini_shop_products")
}

model MiniShopProductPhoto {
  id        String   @id @default(uuid())
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  miniShopProductId String
  miniShopProduct   MiniShopProduct @relation(fields: [miniShopProductId], references: [id], onDelete: Cascade)

  @@index([miniShopProductId])
  @@map("mini_shop_product_photos")
}

model MiniShopProductTag {
  miniShopProductId String
  miniShopProduct   MiniShopProduct @relation(fields: [miniShopProductId], references: [id], onDelete: Cascade)
  tagId             String
  tag               Tag             @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([miniShopProductId, tagId])
  @@map("mini_shop_product_tags")
}
