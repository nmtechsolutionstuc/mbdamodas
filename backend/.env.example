# ── Base de datos ────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mbdamodas"

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET="cambia_esto_por_un_secreto_largo_y_aleatorio"
JWT_REFRESH_SECRET="cambia_esto_por_otro_secreto_largo_y_aleatorio"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Google OAuth ─────────────────────────────────────────────
# Creá las credenciales en: https://console.cloud.google.com
GOOGLE_CLIENT_ID="tu_google_client_id"
GOOGLE_CLIENT_SECRET="tu_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# ── Almacenamiento de fotos ──────────────────────────────────
# "local" para desarrollo, "cloudinary" para producción
STORAGE_PROVIDER="local"

# Cloudinary (solo si STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
